{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WhatsApp Channel Configuration",
  "type": "object",
  "required": ["TWILIO_ACCOUNT_SID", "TWILIO_AUTH_TOKEN", "TWILIO_WHATSAPP_NUMBER"],
  "properties": {
    "TWILIO_ACCOUNT_SID": {
      "type": "string",
      "pattern": "^AC[a-f0-9]{32}$",
      "description": "Twilio Account SID"
    },
    "TWILIO_AUTH_TOKEN": {
      "type": "string",
      "description": "Twilio Auth Token (secret)"
    },
    "TWILIO_WHATSAPP_NUMBER": {
      "type": "string",
      "pattern": "^whatsapp:\\+[0-9]+$",
      "description": "Twilio WhatsApp sender number (e.g., whatsapp:+14155238886)"
    },
    "WEBHOOK_PATH": {
      "type": "string",
      "default": "/webhooks/whatsapp",
      "description": "URL path for Twilio webhook endpoint"
    },
    "DEFAULT_AUTOMATION": {
      "type": "string",
      "default": "ai-data-assistant",
      "description": "Default automation for inbound text messages"
    },
    "SESSION_TIMEOUT_HOURS": {
      "type": "integer",
      "minimum": 1,
      "maximum": 72,
      "default": 24,
      "description": "Hours before an inactive conversation expires"
    },
    "MAX_HISTORY_MESSAGES": {
      "type": "integer",
      "minimum": 5,
      "maximum": 50,
      "default": 20,
      "description": "Number of messages to load for LLM context"
    },
    "STATUS_CALLBACK_URL": {
      "type": "string",
      "format": "uri",
      "description": "URL for Twilio delivery status callbacks"
    },
    "AUTOMATION_ROUTES": {
      "type": "object",
      "description": "Custom routing rules: media_type → automation_id",
      "default": {
        "audio/*": "ai-voice-processor",
        "image/*": "ai-photo-classifier",
        "text": "ai-data-assistant"
      },
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
